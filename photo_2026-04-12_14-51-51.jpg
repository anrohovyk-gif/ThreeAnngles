:root {
    --accent-blue: #00f2ff;
    --accent-pink: #ff0055;
    --glass-bg: rgba(0, 40, 60, 0.7);
    --text-white: #ffffff;
}
body {
    margin: 0;
    padding: 0;
    font-family: 'Segoe UI', Roboto, sans-serif;
    background: linear-gradient(rgba(2, 28, 52, 0.9), rgba(2, 28, 52, 0.9)), 
                url('https://images.unsplash.com/photo-1551244072-5d12893278ab?q=80&w=2000&auto=format&fit=crop');
    background-size: cover;
    background-attachment: fixed;
    color: var(--text-white);
    line-height: 1.6;
    text-align: center;
}
.container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 40px 20px;
}
header h1 {
    color: var(--accent-blue);
    text-transform: uppercase;
    letter-spacing: 5px;
    font-size: 2.5rem;
    margin-bottom: 10px;
}
.subtitle {
    opacity: 0.8;
    max-width: 700px;
    margin: 0 auto 40px;
}
.main-images {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-bottom: 40px;
    flex-wrap: wrap;
}
.main-images img {
    border-radius: 15px;
    border: 2px solid rgba(0, 242, 255, 0.3);
    transition: 0.3s;
    object-fit: cover;
}
.main-images img:hover {
    border-color: var(--accent-blue);
    transform: scale(1.02);
    box-shadow: 0 0 20px rgba(0, 242, 255, 0.4);
}
.tour-details {
    display: grid;
    gap: 25px;
}
.card {
    background: var(--glass-bg);
    backdrop-filter: blur(15px);
    border: 1px solid rgba(0, 242, 255, 0.2);
    border-radius: 20px;
    padding: 25px;
    text-align: left;
    transition: 0.3s;
    position: relative;
    overflow: hidden;
}
.card:hover {
    border-color: var(--accent-blue);
    background: rgba(0, 50, 80, 0.8);
}

.card.waiting::before {
    background: var(--accent-pink);
    box-shadow: 0 0 10px var(--accent-pink);
}
.card ul {
    list-style: none;
    padding: 0;
    margin: 0;
}
.card li {
    margin-bottom: 8px;
}
.card strong {
    color: var(--accent-blue);
    font-size: 1.3rem;
    display: block;
    margin-bottom: 10px;
}
button {
    background: transparent;
    border: 2px solid var(--accent-blue);
    color: var(--accent-blue);
    padding: 12px 30px;
    border-radius: 8px;
    cursor: pointer;
    font-weight: bold;
    text-transform: uppercase;
    transition: 0.3s;
    margin-top: 40px;
}
button:hover {
    background: var(--accent-blue);
    color: #0a2d42;
    box-shadow: 0 0 20px var(--accent-blue);
}